# --- Vercel (build-time) ---
# Full URL to index.php on Railway, HTTPS:
# API_BASE_URL=https://your-service.up.railway.app/index.php

# --- Railway web service (PHP API) ---
# Reference variables from a linked MySQL plugin, or set manually:

# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLDATABASE=h2zero_inventory
# MYSQLUSER=
# MYSQLPASSWORD=

# Alternative names (optional):
# DB_HOST=
# DB_PORT=3306
# DB_NAME=h2zero_inventory
# DB_USER=
# DB_PASSWORD=

# Comma-separated browser origins allowed to call the API (your Vercel URLs + local dev):
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5500

# Set to 1 to allow any https://*.vercel.app origin (useful for preview deployments):
# ALLOW_VERCEL_PREVIEWS=1

# If the app is behind HTTPS but forwarded-proto is wrong, force cross-site session cookies:
# SESSION_SAMESITE_NONE=1

# Allow POST /index.php?route=auth&action=signup (public staff self-registration)
# ALLOW_PUBLIC_STAFF_SIGNUP=1

# Set to 1 to skip auto-creating default admin (admin@gmail.com) when no admin exists
# DISABLE_AUTO_ADMIN=1
